{
  "expo": {
    "name": "Maximo",
    "slug": "calc-optimizer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#1a1a2e"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#faf6f0"
      },
      "package": "com.calcoptimizer.app",
      "permissions": [
        "CAMERA",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "softwareKeyboardLayoutMode": "pan"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Maximo to access your camera to scan math problems."
        }
      ],
      "expo-asset",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Maximo to save captured photos to your gallery.",
          "savePhotosPermission": "Allow Maximo to save captured photos to your gallery."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "63640b8c-6b5e-41b5-b88a-5df1911b5f34"
      }
    }
  }
}
